{
  "name": "cortask",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "Local AI agent with skills, workspaces, and cron",
  "repository": {
    "type": "git",
    "url": "https://github.com/cortask/cortask.git",
    "directory": "packages/cli"
  },
  "files": ["dist"],
  "bin": {
    "cortask": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@cortask/core": "workspace:*",
    "@cortask/gateway": "workspace:*",
    "chalk": "^5.6.2",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
