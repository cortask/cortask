{
  "credentials": [
    {
      "id": "api-key",
      "type": "api-key",
      "name": "Notion API Key",
      "description": "Internal integration token from https://www.notion.so/my-integrations",
      "fields": [
        {
          "key": "apiKey",
          "label": "Notion API Key",
          "type": "secret",
          "required": true,
          "placeholder": "secret_••••••••••••",
          "validation": {
            "pattern": "^secret_[a-zA-Z0-9]{43}$",
            "message": "Must be a valid Notion integration token (starts with 'secret_')"
          }
        }
      ]
    }
  ]
}
